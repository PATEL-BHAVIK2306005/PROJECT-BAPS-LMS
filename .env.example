APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=elearning
DB_USERNAME=root
DB_PASSWORD=

DB_STATE=online
DB_ACTIVE_CONNECTION=mysql_online

DB_ONLINE_CONNECTION=mysql
DB_ONLINE_HOST=
DB_ONLINE_PORT=4000
DB_ONLINE_DATABASE=test
DB_ONLINE_USERNAME=
DB_ONLINE_PASSWORD=
DB_ONLINE_SSL=true

DB_GCP_CONNECTION=mysql
DB_GCP_HOST=127.0.0.1
DB_GCP_PORT=3306
DB_GCP_DATABASE=gcp_db
DB_GCP_USERNAME=
DB_GCP_PASSWORD=
DB_GCP_SSL=false
DB_GCP_SSL_CA=

DB_ITMBU_CONNECTION=mysql
DB_ITMBU_HOST=127.0.0.1
DB_ITMBU_PORT=3306
DB_ITMBU_DATABASE=itmbu_db
DB_ITMBU_USERNAME=
DB_ITMBU_PASSWORD=

DB_MONGODB_CONNECTION=mongodb
DB_MONGODB_HOST=127.0.0.1
DB_MONGODB_PORT=27017
DB_MONGODB_DATABASE=mongodb_db
DB_MONGODB_USERNAME=
DB_MONGODB_PASSWORD=
DB_MONGODB_AUTH_DATABASE=admin

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Custom Ngrok public tunnel link domain (register yours on ngrok.com)
NGROK_DOMAIN=baps-lms-seva.ngrok-free.app
